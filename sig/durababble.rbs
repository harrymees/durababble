module Durababble
  type serialized_payload = Object?
  type payload_map = Hash[String | Symbol, serialized_payload]
  type workflow_row = Hash[String, serialized_payload]
  type lease_release_counts = Hash[String, Integer]
  type workflow_registry = Array[singleton(Workflow[serialized_payload, serialized_payload])] | Hash[String, singleton(Workflow[serialized_payload, serialized_payload])]
  type object_registry = Array[singleton(DurableObject[serialized_payload, serialized_payload])] | Hash[String, singleton(DurableObject[serialized_payload, serialized_payload])]
  type retry_config = {
    ?initial_interval: Numeric,
    ?backoff_coefficient: Float,
    ?maximum_interval: Numeric?,
    ?maximum_attempts: Integer?,
    ?schedule: Array[Numeric],
    ?non_retryable_errors: Array[Class | String | Symbol]
  }

  interface _WorkflowRpcHandler
    def call: (payload_map payload) -> serialized_payload
  end

  interface _RpcAuthorize
    def call: (Object call) -> bool
  end

  interface _AwakenBatchHandler
    def call: (worker_pool: String, workflow_ids: Array[String]) -> void
  end

  interface _TargetMessageHandler
    def call: (worker_pool: String, target_kind: String, target_class: String, target_id: String) -> void
  end

  interface _RpcDeliverMessageClient
    def deliver_message: (worker_pool: String, target_kind: String, ?target_class: String, target_id: String) -> true
  end

  interface _RpcClientFactory
    def call: (String address) -> _RpcDeliverMessageClient
  end

  interface _TransientHandler
    def call: (request: Object, args: serialized_payload) -> serialized_payload
  end

  interface _RpcRequester
    def request: (String command, payload_map payload) -> serialized_payload
  end

  interface _LeaseStarter
    def call: (workflow_id: String) -> workflow_row
  end

  interface _Sleeper
    def call: (Integer attempt) -> void
  end

  class Error < StandardError
  end

  class InjectedCrash < Error
  end

  class LeaseConflict < Error
  end

  class NonDeterminismError < Error
  end

  class FenceTimeout < Error
  end

  class CommandTimeout < Error
  end

  class IdempotencyKeyConflict < Error
  end

  class CancellationError < Error
    attr_reader workflow_id: String?
    attr_reader reason: serialized_payload
    def initialize: (?serialized_payload reason, ?workflow_id: String?) -> void
  end

  module Observability
    class Configuration
      attr_reader attributes: Hash[String, serialized_payload]
      def enabled?: () -> bool
      def tracer: () -> Object?
      def meter: () -> Object?
    end
  end

  class Step
    attr_reader name: String
    attr_reader retry_policy: RetryPolicy
  end

  class StepRetryScheduled < Error
  end

  class WorkflowSuspended < Error
  end

  class StepContext
    attr_reader workflow_id: String
    attr_reader step_index: Integer
    attr_reader attempt_number: Integer
    attr_reader idempotency_key: String
    attr_reader heartbeat: Heartbeat
  end

  class CommandContext
    attr_reader object_type: String
    attr_reader durable_id: String
    attr_reader command_id: String
    attr_reader attempt_number: Integer
    attr_reader idempotency_key: String
  end

  class Heartbeat
    attr_reader cursor: serialized_payload
    def record: (?serialized_payload cursor) -> true
    def heartbeat: (?serialized_payload cursor) -> true
  end

  class Run[Output]
    attr_reader id: String
    attr_reader status: String
    attr_reader result: Output?
    attr_reader error: String?
  end

  def self.configure_observability: (?enabled: bool, ?attributes: Hash[String | Symbol, serialized_payload]) -> Observability::Configuration
  def self.observability: () -> Observability::Configuration

  class Store
    attr_reader schema: String
    attr_accessor rpc_client_factory: _RpcClientFactory

    def self.connect: (database_url: String, ?schema: String) -> Store

    def initialize: (Object connection, schema: String) -> void
    def migrate!: () -> self
    def drop_schema!: () -> void
    def close: () -> void
    def current_time: () -> Time
    def enqueue_workflow: (name: String, input: serialized_payload) -> String
    def create_workflow: (name: String, input: serialized_payload) -> String
    def claim_runnable_workflow: (worker_id: String, lease_seconds: Numeric, ?workflow_names: Array[String]) -> workflow_row?
    def claim_workflow: (workflow_id: String, worker_id: String, lease_seconds: Numeric) -> workflow_row?
    def claim_workflow_for_activation: (workflow_id: String, worker_id: String, lease_seconds: Numeric) -> workflow_row?
    def heartbeat: (workflow_id: String, worker_id: String, lease_seconds: Numeric) -> Object
    def workflow_owned?: (workflow_id: String, worker_id: String) -> bool
    def release_worker_leases!: (worker_id: String) -> lease_release_counts
    def schedule_workflow_retry: (workflow_id: String, worker_id: String, run_at: Time) -> void
    def suspend_workflow: (workflow_id: String, ?worker_id: String?) -> bool
    def make_workflow_due!: (String workflow_id, ?now: Time) -> void
    def heartbeat_step: (workflow_id: String, worker_id: String, lease_seconds: Numeric, cursor: serialized_payload, ?command_id: Integer?, ?position: Integer?) -> bool
    def step_heartbeat_cursor: (workflow_id: String, ?command_id: Integer?, ?position: Integer?) -> serialized_payload
    def current_workflow_lease: (String workflow_id) -> workflow_row?
    def deliver_target_message: (target_kind: String, target_type: String, target_id: String, ?worker_pool: String, ?client_factory: _RpcClientFactory?) -> bool
    def steal_expired_leases!: (?now: Time) -> Integer
    def mark_workflow_running: (String workflow_id, ?worker_id: String?, ?lease_seconds: Numeric) -> workflow_row?
    def complete_workflow: (String workflow_id, result: serialized_payload, ?worker_id: String?) -> void
    def cancel_workflow: (String workflow_id, reason: String?, ?result: serialized_payload, ?worker_id: String?) -> void
    def fail_workflow: (String workflow_id, error: String, ?worker_id: String?) -> void
    def record_step_scheduled: (workflow_id: String, command_id: Integer, name: String, ?args: Array[serialized_payload], ?kwargs: Hash[Symbol, serialized_payload], ?metadata: Hash[String, serialized_payload], ?worker_id: String?) -> void
    def record_step_started: (workflow_id: String, name: String, ?command_id: Integer?, ?position: Integer?, ?worker_id: String?) -> String
    def record_step_completed: (workflow_id: String, result: serialized_payload, ?command_id: Integer?, ?position: Integer?, ?worker_id: String?) -> void
    def record_step_failed: (workflow_id: String, error: String, ?command_id: Integer?, ?position: Integer?, ?worker_id: String?) -> void
    def record_step_canceled: (workflow_id: String, error: String, ?command_id: Integer?, ?position: Integer?, ?worker_id: String?) -> void
    def record_wait: (workflow_id: String, name: String, wait_request: WaitRequest, ?command_id: Integer?, ?position: Integer?, ?suspend_workflow: bool, ?worker_id: String?) -> String
    def workflow_history_for: (String workflow_id) -> Array[workflow_row]
    def wake_due_timers: (?now: Time) -> Integer
    def waits_for: (String workflow_id) -> Array[workflow_row]
    def with_fence: (workflow_id: String, key: String, ?poll_interval: Numeric, ?timeout: Numeric) { () -> serialized_payload } -> serialized_payload
    def enqueue_outbox: (workflow_id: String, topic: String, payload: serialized_payload, key: String) -> String
    def claim_outbox: (worker_id: String, lease_seconds: Numeric) -> workflow_row?
    def ack_outbox: (String outbox_id, worker_id: String) -> bool
    def outbox_message: (String outbox_id) -> workflow_row?
    def enqueue_inbox_message: (target_kind: String, target_type: String, target_id: String, message_kind: String, ?method_name: String?, ?payload: serialized_payload, ?idempotency_key: String?, ?ready_at: Time?, ?max_attempts: Integer?) -> String
    def enqueue_workflow_command: (workflow_id: String, workflow_name: String, method_name: String, payload: serialized_payload, ?idempotency_key: String?) -> String
    def claim_target_activation: (worker_id: String, lease_seconds: Numeric, ?target_kinds: Array[String]?, ?target_types: Array[String]?, ?now: Time) -> workflow_row?
    def complete_target_activation: (target_kind: String, target_type: String, target_id: String, worker_id: String, ?now: Time) -> Object?
    def reconcile_target_activation: (target_kind: String, target_type: String, target_id: String, ?now: Time) -> Object?
    def rearm_target_activation: (target_kind: String, target_type: String, target_id: String, ready_at: Time) -> Object?
    def target_activation: (target_kind: String, target_type: String, target_id: String) -> workflow_row?
    def claim_inbox_messages: (target_kind: String, target_type: String, target_id: String, worker_id: String, ?lease_seconds: Numeric, ?limit: Integer, ?now: Time) -> Array[workflow_row]
    def inbox_message: (String message_id) -> workflow_row?
    def wait_for_inbox_message: (String message_id, ?poll_interval: Numeric, ?timeout: Numeric?) -> serialized_payload
    def inbox_messages_for: (target_kind: String, target_type: String, target_id: String) -> Array[workflow_row]
    def workflow: (String workflow_id) -> workflow_row
    def steps_for: (String workflow_id) -> Array[workflow_row]
    def step_attempts_for: (String workflow_id) -> Array[workflow_row]
    def object_state: (object_type: String, object_id: String) -> serialized_payload
    def save_object_state: (object_type: String, object_id: String, state: serialized_payload) -> void
    def enqueue_object_command: (object_type: String, object_id: String, method_name: String, args: Array[serialized_payload], kwargs: Hash[Symbol, serialized_payload], ?message_kind: String, ?idempotency_key: String?, ?max_attempts: Integer?) -> String
    def claim_object_command: (command_id: String, worker_id: String, ?lease_seconds: Numeric) -> workflow_row?
    def complete_object_command: (command_id: String, result: serialized_payload, ?object_type: String?, ?object_id: String?, ?state: serialized_payload, ?worker_id: String?) -> Object?
    def fail_object_command: (command_id: String, error: String, ?worker_id: String?, ?terminal: bool) -> Object?
    def retry_object_command: (command_id: String, error: String, worker_id: String, ready_at: Time) -> Object?
    def complete_workflow_command: (message_id: String, workflow_id: String, result: serialized_payload, worker_id: String) -> Object?
    def fail_workflow_command: (message_id: String, workflow_id: String, error: String, worker_id: String) -> Object?
  end

  class Workflow[Input, Output]
    def self.workflow_name: (?String value) -> String
    def self.enqueue: (Input input, ?store: Store) -> String
    def self.start: (Input input, ?store: Store) -> WorkflowRef[Input, Output]
    def self.ref: (String workflow_id, ?store: Store) -> WorkflowRef[Input, Output]
    def self.handle: (String workflow_id, ?store: Store) -> WorkflowRef[Input, Output]
    def self.step: (?Symbol method_name, ?retry: retry_config | false | nil) -> Symbol?
    def self.expose: (?Symbol method_name) -> Symbol?
    def self.expose_command: (?Symbol method_name, ?retry: retry_config | false | nil) -> Symbol?

    def __durababble_execution__: () -> WorkflowExecution
    def __durababble_execution__=: (WorkflowExecution? execution) -> WorkflowExecution?
    def execute: (Input input) -> Output
    def step_context: () -> StepContext
    def wait_until: (Time time, ?serialized_payload context) -> serialized_payload
    def sleep_until: (Time time, ?serialized_payload context) -> serialized_payload
    def sleep: (Numeric duration, ?serialized_payload context) -> serialized_payload
    def wait_condition: (?timeout: Numeric?) { () -> bool } -> bool
  end

  class WorkflowRef[Input, Output]
    attr_reader workflow_id: String

    def initialize: (singleton(Workflow[Input, Output]) workflow_class, String workflow_id, store: Store) -> void
    def cancel: (?reason: serialized_payload) -> Run[serialized_payload]
    def method_missing: (Symbol method_name, *serialized_payload args, **serialized_payload kwargs) -> serialized_payload
    def respond_to_missing?: (Symbol method_name, ?bool include_private) -> bool
  end

  class DurableObject[Id, State]
    def self.object_type: (?String value) -> String
    def self.ref: (Id durable_id, ?store: Store) -> DurableObjectRef[Id, State]
    def self.at: (Id durable_id, ?store: Store, ?worker_pool: String?, ?idempotency_key: String?) -> DurableObjectRef[Id, State]
    def self.tell: (Id durable_id, Symbol method_name, *serialized_payload args, ?store: Store, ?idempotency_key: String?, **serialized_payload kwargs) -> String
    def self.expose: (?Symbol method_name) -> Symbol?
    def self.expose_command: (?Symbol method_name, ?retry: retry_config | false | nil) -> Symbol?

    attr_reader durable_id: Id
    attr_reader command_context: CommandContext?

    def initialize_state: () -> State
    def current_state: () -> State
    def update_state: (State state) -> State
    def state_dirty?: () -> bool
  end

  class DurableObjectRef[Id, State]
    attr_reader durable_id: Id

    def initialize: (singleton(DurableObject[Id, State]) object_class, Id durable_id, store: Store) -> void
    def method_missing: (Symbol method_name, *serialized_payload args, **serialized_payload kwargs) -> serialized_payload
    def respond_to_missing?: (Symbol method_name, ?bool include_private) -> bool
  end

  class DurableObjectExecutor
    def initialize: (store: Store, objects: object_registry, worker_id: String, lease_seconds: Numeric) -> void
    def drain_object_inbox: (String object_type, object_id: String, ?limit: Integer) -> Integer
  end

  class WaitRequest
    attr_reader kind: String
    attr_reader wake_at: Time?
    attr_reader event_key: String?
    attr_reader context: serialized_payload

    def initialize: (kind: String, wake_at: Time?, event_key: String?, context: serialized_payload) -> void
  end

  class Engine
    def initialize: (store: Store, ?worker_id: String, ?lease_seconds: Numeric, ?migrate: bool, ?crash_after: Symbol?) -> void
    def run: [Input, Output] (singleton(Workflow[Input, Output]) workflow_class, input: Input) -> Run[Output]
    def resume: [Input, Output] (singleton(Workflow[Input, Output]) workflow_class, workflow_id: String, ?claimed: workflow_row?) -> Run[Output]
    def drain_workflow_inbox: [Input, Output] (singleton(Workflow[Input, Output]) workflow_class, workflow_id: String, ?claimed: workflow_row?, ?limit: Integer) -> Integer
  end

  class Worker
    def initialize: (store: Store, workflows: workflow_registry, worker_id: String, ?objects: object_registry, ?lease_seconds: Numeric, ?migrate: bool) -> void
    def tick: () -> Symbol
    def deliver_target: (target_kind: String, target_type: String, target_id: String) -> Symbol
    def run_until_idle: (?max_ticks: Integer) -> Integer
  end

  class WorkerRuntime
    attr_reader store: Store
    attr_reader workflows: workflow_registry
    attr_reader objects: object_registry
    attr_reader worker_pool: String
    attr_reader worker_id: String
    attr_reader last_error: StandardError?
    attr_reader rpc_address: String?

    def self.start: (workflows: workflow_registry, worker_pool: String, ?objects: object_registry, ?store: Store?, ?database_url: String?, ?schema: String?, ?worker_id: String?, ?lease_seconds: Numeric, ?poll_interval: Numeric, ?migrate: bool, ?rpc_host: String, ?rpc_port: Integer, ?rpc_credentials: Rpc::credentials, ?rpc_pool_size: Integer) -> WorkerRuntime

    def initialize: (workflows: workflow_registry, worker_pool: String, ?objects: object_registry, ?store: Store?, ?database_url: String?, ?schema: String?, ?worker_id: String?, ?lease_seconds: Numeric, ?poll_interval: Numeric, ?migrate: bool, ?rpc_host: String, ?rpc_port: Integer, ?rpc_credentials: Rpc::credentials, ?rpc_pool_size: Integer) -> void
    def start: () -> self
    def shutdown: (?timeout: Numeric) -> :stopped | :timeout
    def stop: (?timeout: Numeric) -> :stopped | :timeout
    def wait: (?timeout: Numeric?) -> Thread?
    def running?: () -> bool
    def close: () -> void
  end

  class WorkflowExecution
    attr_reader step_context: StepContext?
    def call_step: (Workflow[serialized_payload, serialized_payload] instance, method_name: Symbol, args: Array[serialized_payload], kwargs: Hash[Symbol, serialized_payload]) { () -> serialized_payload } -> serialized_payload
    def call_wait: (WaitRequest wait_request, name: String, ?args: Array[serialized_payload], ?kwargs: Hash[Symbol, serialized_payload]) -> serialized_payload
    def wait_condition: (?timeout: Numeric?) { () -> bool } -> bool
    def timer_after: (Numeric duration) -> Time
    def validate_replay_complete!: () -> void
  end

  class RetryPolicy
    attr_reader initial_interval: Float
    attr_reader backoff_coefficient: Float
    attr_reader maximum_interval: Float?
    attr_reader maximum_attempts: Integer | Float
    attr_reader schedule: Array[Float]
    attr_reader non_retryable_errors: Array[Class | String | Symbol]

    def self.from: (retry_config | RetryPolicy | nil value) -> RetryPolicy

    def initialize: (?initial_interval: Numeric, ?backoff_coefficient: Numeric, ?maximum_interval: Numeric?, ?maximum_attempts: Integer?, ?schedule: Array[Numeric]?, ?non_retryable_errors: Array[Class | String | Symbol]) -> void
    def retryable?: (StandardError error, attempt_number: Integer) -> bool
    def delay_for_attempt: (Integer attempt_number) -> Float
  end

  class RpcClient
    class Error < Durababble::Error
    end

    class RemoteError < Error
    end

    class ConnectionError < Error
    end

    class EOFError < ConnectionError
    end

    class TimeoutError < ConnectionError
    end

    def self.spawn: (command: Array[String], ?env: Hash[String, String], ?timeout: Numeric) -> RpcClient

    def request: (String command, ?payload_map payload) -> serialized_payload
    def close: () -> void
  end

  module WorkflowRpc
    class Error < Durababble::Error
    end

    class WorkflowNotRunning < Error
    end

    class NoActiveLease < WorkflowNotRunning
    end

    class NodeUnavailable < Error
    end

    class StaleLease < Error
    end

    class UnknownCommand < Error
    end

    def self.remote_error_from_message: (String message) -> Error?
    def self.remote_error_from_fields: (String klass_name, String message) -> Error?

    class LeaseStarter
      def initialize: (store: Store, worker_ids: Array[String], ?lease_seconds: Numeric, ?await_attempts: Integer, ?await_sleep: _Sleeper) -> void
      def call: (workflow_id: String) -> workflow_row
    end

    class Router
      def initialize: (store: Store, rpc_clients: Hash[String, _RpcRequester], ?retry_on_stale: bool, ?start_workflow: _LeaseStarter?) -> void
      def request: (workflow_id: String, command: String, ?payload: payload_map) -> serialized_payload
    end

    class Handler
      def initialize: (store: Store, node_id: String, handlers: Hash[String, _WorkflowRpcHandler]) -> void
      def call: (payload_map payload) -> serialized_payload
    end
  end

  module Rpc
    type credentials = Object

    class Error < Durababble::Error
    end

    class Unavailable < Error
    end

    class Unauthenticated < Error
    end

    class NodeDirectory
      def initialize: (?Hash[String, String] entries) -> void
      def register: (node_id: String, rpc_address: String) -> String
      def rpc_address_for: (String node_id) -> String?
    end

    module Proto
      class Message
      end

      class AwakenBatchResponse < Message
      end

      class DeliverMessageResponse < Message
      end

      class EvictLeaseResponse < Message
      end

      class TransientResponse < Message
      end

      class Stub
      end
    end

    class Client
      attr_reader address: String

      def initialize: (address: String, ?credentials: credentials, ?timeout: Numeric, ?stub: Proto::Stub?) -> void
      def awaken_batch: (worker_pool: String, workflow_ids: Array[String]) -> true
      def evict_lease: (worker_pool: String, target_kind: String, ?target_class: String, target_id: String) -> true
      def deliver_message: (worker_pool: String, target_kind: String, ?target_class: String, target_id: String) -> true
      def call_transient_response: (worker_pool: String, method: String, args: serialized_payload, ?class_name: String, ?object_id: String, ?workflow_id: String, ?deadline_ms: Integer) -> Proto::TransientResponse
      def call_transient: (worker_pool: String, method: String, args: serialized_payload, ?class_name: String, ?object_id: String, ?workflow_id: String, ?deadline_ms: Integer) -> serialized_payload
    end

    class WorkflowClient
      def initialize: (address: String, ?worker_pool: String, ?credentials: credentials, ?timeout: Numeric) -> void
      def request: (String command, Hash[String, serialized_payload] payload) -> serialized_payload
    end

    class Server
      attr_reader node_id: String
      attr_reader host: String
      attr_reader port: Integer?

      def initialize: (node_id: String?, store: Store, ?worker_pool: String, ?workflow_handlers: Hash[String, _WorkflowRpcHandler], ?transient_handler: _TransientHandler?, ?node_directory: NodeDirectory, ?host: String, ?port: Integer, ?credentials: credentials, ?pool_size: Integer, ?authorize: _RpcAuthorize?, ?awaken_batch: _AwakenBatchHandler?, ?evict_lease: _TargetMessageHandler?, ?deliver_message: _TargetMessageHandler?, ?verify_deliver_message_owner: bool) -> void
      def start: () -> self
      def stop: () -> void
      def address: () -> String
    end
  end

  attr_accessor self.default_store: Store?

  def self.default_database_url: () -> String
  def self.default_schema: () -> String
  def self.workspace_schema: (?String? workspace_path, ?prefix: String) -> String
  def self.configure: (database_url: String, ?schema: String) -> Store
  def self.store: () -> Store
  def self.wait_until: (Time time, ?serialized_payload context) -> serialized_payload
  def self.sleep_until: (Time time, ?serialized_payload context) -> serialized_payload
  def self.sleep: (Numeric duration, ?serialized_payload context) -> serialized_payload
  def self.wait_condition: (?timeout: Numeric?) { () -> bool } -> bool
end
