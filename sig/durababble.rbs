module Async
  module HTTP
    class Client
    end
  end
end

module Durababble
  type serialized_payload = Object?
  type payload_map = Hash[String | Symbol, serialized_payload]
  type workflow_row = Hash[String, serialized_payload]
  type workflow_handle[Input, Output, Dispatch] = WorkflowRef[Input, Output] & Dispatch
  type durable_object_handle[Id, State, Dispatch] = DurableObjectRef[Id, State] & Dispatch
  type lease_release_counts = Hash[String, Integer]
  type workflow_registry = Array[singleton(Workflow)] | Hash[String, singleton(Workflow)]
  type object_registry = Array[singleton(DurableObject)] | Hash[String, singleton(DurableObject)]
  type retry_config = {
    ?initial_interval: Numeric,
    ?backoff_coefficient: Float,
    ?maximum_interval: Numeric?,
    ?maximum_attempts: Integer?,
    ?schedule: Array[Numeric],
    ?non_retryable_errors: Array[Class | String | Symbol]
  }

  interface _ActiveRecordConnection
    def adapter_name: () -> String
    def exec_query: (String sql, ?String? name, ?Array[Object?] binds, ?prepare: bool) -> Object
    def quote_column_name: (String identifier) -> String
    def transaction: (?requires_new: bool, **Object?) { () -> Object? } -> Object?
  end

  interface _ActiveRecordConnectionPool
    def with_connection: [Result] () { (_ActiveRecordConnection) -> Result } -> Result
    def disconnect!: () -> void
    def active_connection?: () -> bool
  end

  interface _ActiveRecordOwner
    def connection_pool: () -> _ActiveRecordConnectionPool
  end

  interface _WorkflowRpcHandler
    def call: (payload_map payload) -> serialized_payload
  end

  interface _RpcAuthorize
    def call: (Object call) -> bool
  end

  interface _AwakenBatchHandler
    def call: (worker_pool: String, workflow_ids: Array[String]) -> void
  end

  interface _TargetMessageHandler
    def call: (worker_pool: String, target_kind: String, target_class: String, target_id: String) -> void
  end

  interface _RpcDeliverMessageClient
    def deliver_message: (worker_pool: String, target_kind: String, ?target_class: String, target_id: String, ?expected_worker_id: String) -> true
    def call_transient: (worker_pool: String, method: String, args: serialized_payload, ?class_name: String, ?durable_object_id: String, ?workflow_id: String, ?deadline_ms: Integer, ?expected_worker_id: String) -> serialized_payload
  end

  interface _RpcClientFactory
    def call: (String address) -> _RpcDeliverMessageClient
  end

  interface _TransientHandler
    def call: (request: Object, args: serialized_payload) -> serialized_payload
  end

  interface _WorkerIdProvider
    def call: () -> String
  end

  interface _RpcRequester
    def request: (String command, payload_map payload) -> serialized_payload
  end

  interface _WorkflowRpcClientFactory
    def call: (String address, worker_pool: String) -> _RpcRequester
  end

  interface _WorkflowRpcRouteClientFactory
    def call: (String worker_id, worker_pool: String) -> _RpcRequester
  end

  interface _LeaseStarter
    def call: (workflow_id: String) -> workflow_row
  end

  interface _Sleeper
    def call: (Integer attempt) -> void
  end

  class Error < StandardError
  end

  class InjectedCrash < Error
  end

  class LeaseConflict < Error
  end

  class DeterminismError < Error
  end

  class NonDeterminismError < DeterminismError
  end

  class WorkflowHistoryLimitExceeded < Error
    attr_reader workflow_id: String
    attr_reader history_events: Integer
    attr_reader max_history_events: Integer
    def initialize: (String workflow_id, history_events: Integer, max_history_events: Integer) -> void
  end

  class FenceTimeout < Error
  end

  class CommandTimeout < Error
  end

  class ObjectReadBlocked < Error
  end

  class IdempotencyKeyConflict < Error
  end

  class PayloadTooLarge < Error
    attr_reader surface: Symbol
    attr_reader context: String?
    attr_reader bytesize: Integer
    attr_reader max_bytes: Integer
    def initialize: ((Symbol | String) surface, bytesize: Integer, max_bytes: Integer, ?context: String?) -> void
  end

  class WorkflowAlreadyExists < Error
  end

  class CancellationError < Error
    attr_reader workflow_id: String?
    attr_reader reason: serialized_payload
    def initialize: (?serialized_payload reason, ?workflow_id: String?) -> void
  end

  module Observability
    class Configuration
      attr_reader attributes: Hash[String, serialized_payload]
      def enabled?: () -> bool
      def tracer: () -> Object?
      def meter: () -> Object?
    end
  end

  class Step
    attr_reader name: String
    attr_reader retry_policy: RetryPolicy
  end

  class StepRetryScheduled < Error
  end

  class WorkflowSuspended < Error
  end

  class StepContext
    attr_reader workflow_id: String
    attr_reader step_index: Integer
    attr_reader attempt_number: Integer
    attr_reader idempotency_key: String
    attr_reader heartbeat: Heartbeat
  end

  class CommandContext
    attr_reader object_type: String
    attr_reader durable_id: String
    attr_reader command_id: String
    attr_reader attempt_number: Integer
    attr_reader idempotency_key: String
  end

  class Heartbeat
    attr_reader cursor: serialized_payload
    def record: (?serialized_payload cursor) -> true
    def heartbeat: (?serialized_payload cursor) -> true
  end

  class Run[Output]
    attr_reader id: String
    attr_reader status: String
    attr_reader result: Output?
    attr_reader error: String?
  end

  def self.configure_observability: (?enabled: bool, ?attributes: Hash[String | Symbol, serialized_payload]) -> Observability::Configuration
  def self.observability: () -> Observability::Configuration
  def self.max_workflow_history_events: () -> Integer
  def self.max_workflow_history_events=: ((Integer | String) value) -> (Integer | String)
  def self.workflow_history_warning_events: () -> Integer
  def self.workflow_history_warning_events=: ((Integer | String) value) -> (Integer | String)
  def self.payload_limits: () -> Hash[Symbol, Integer]
  def self.payload_limits=: (Hash[Symbol | String, Integer | String] limits) -> Hash[Symbol | String, Integer | String]
  def self.logger: () -> Object?
  def self.logger=: (Object? logger) -> Object?
  def self.enforce_payload_limit!: (surface: Symbol | String, bytesize: Integer, ?context: String?) -> true
  def self.warn_workflow_history_events: (workflow_id: String, history_events: Integer, max_history_events: Integer) -> bool

  class Store
    attr_reader schema: String
    attr_reader connection_pool: _ActiveRecordConnectionPool
    attr_accessor rpc_client_factory: _RpcClientFactory
    attr_accessor workflow_rpc_client_factory: _WorkflowRpcClientFactory
    attr_accessor local_workflow_rpc_node_id: String?
    attr_accessor local_workflow_rpc_handlers: Hash[String, _WorkflowRpcHandler]?
    attr_accessor local_worker_id: (String | _WorkerIdProvider)?
    attr_accessor local_transient_handler: _TransientHandler?

    def self.connect: (database_url: String, ?schema: String) -> Store
    def self.from_active_record: (connection_pool: _ActiveRecordConnectionPool, ?schema: String, ?owner: _ActiveRecordOwner?) -> Store
    def self.new: (connection_pool: _ActiveRecordConnectionPool, schema: String, ?owner: _ActiveRecordOwner?) -> Store

    def initialize: (_ActiveRecordConnectionPool connection_pool, schema: String, ?owner: _ActiveRecordOwner?) -> void
    def migrate!: () -> self
    def drop_schema!: () -> void
    def close: () -> void
    def with_dedicated_connection: () { (Store store) -> serialized_payload } -> serialized_payload
    def current_time: () -> Time
    def enqueue_workflow: (name: String, input: serialized_payload, ?id: String?, ?worker_pool: String) -> String
    def create_workflow: (name: String, input: serialized_payload, ?worker_id: String?, ?lease_seconds: Numeric, ?worker_pool: String) -> String
    def claim_runnable_workflow: (worker_id: String, lease_seconds: Numeric, ?workflow_names: Array[String], ?worker_pool: String) -> workflow_row?
    def claim_workflow: (workflow_id: String, worker_id: String, lease_seconds: Numeric, ?worker_pool: String) -> workflow_row?
    def claim_workflow_for_activation: (workflow_id: String, worker_id: String, lease_seconds: Numeric, ?worker_pool: String) -> workflow_row?
    def heartbeat: (workflow_id: String, worker_id: String, lease_seconds: Numeric) -> Object
    def workflow_owned?: (workflow_id: String, worker_id: String) -> bool
    def release_worker_leases!: (worker_id: String) -> lease_release_counts
    def schedule_workflow_retry: (workflow_id: String, worker_id: String, run_at: Time) -> Object?
    def suspend_workflow: (workflow_id: String, ?worker_id: String?) -> bool
    def make_workflow_due!: (String workflow_id, ?now: Time) -> Object?
    def heartbeat_step: (workflow_id: String, worker_id: String, lease_seconds: Numeric, cursor: serialized_payload, ?command_id: Integer?, ?position: Integer?) -> Object?
    def step_heartbeat_cursor: (workflow_id: String, ?command_id: Integer?, ?position: Integer?) -> serialized_payload
    def current_workflow_lease: (String workflow_id, ?worker_pool: String?) -> workflow_row?
    def current_object_lease: (String object_type, String object_id) -> workflow_row?
    def deliver_target_message: (target_kind: String, target_type: String, target_id: String, ?worker_pool: String, ?client_factory: _RpcClientFactory?) -> bool
    def steal_expired_leases!: (?now: Time) -> Integer
    def mark_workflow_running: (String workflow_id, ?worker_id: String?, ?lease_seconds: Numeric, ?worker_pool: String) -> Object?
    def complete_workflow: (String workflow_id, result: serialized_payload, ?worker_id: String?) -> Object
    def cancel_workflow: (String workflow_id, reason: String?, ?result: serialized_payload, ?worker_id: String?) -> Object
    def fail_workflow: (String workflow_id, error: String, ?worker_id: String?) -> Object
    def record_step_scheduled: (workflow_id: String, command_id: Integer, name: String, ?args: Array[serialized_payload], ?kwargs: Hash[Symbol, serialized_payload], ?metadata: Hash[String, serialized_payload], ?worker_id: String?) -> void
    def record_step_started: (workflow_id: String, name: String, ?command_id: Integer?, ?position: Integer?, ?worker_id: String?) -> String
    def record_step_completed: (workflow_id: String, result: serialized_payload, ?command_id: Integer?, ?position: Integer?, ?worker_id: String?) -> void
    def record_step_failed: (workflow_id: String, error: String, ?command_id: Integer?, ?position: Integer?, ?worker_id: String?, ?terminal: bool, ?error_class: String?, ?error_message: String?) -> void
    def record_step_failed_and_schedule_retry: (workflow_id: String, error: String, run_at: Time, worker_id: String, ?command_id: Integer?, ?position: Integer?) -> Object?
    def record_step_canceled: (workflow_id: String, error: String, ?command_id: Integer?, ?position: Integer?, ?worker_id: String?) -> void
    def record_wait: (workflow_id: String, name: String, wait_request: WaitRequest, ?command_id: Integer?, ?position: Integer?, ?suspend_workflow: bool, ?worker_id: String?) -> String
    def workflow_history_for: (String workflow_id) -> Array[workflow_row]
    def workflow_history_count_for: (String workflow_id) -> Integer
    def wake_due_timers: (?now: Time, ?batch_size: Integer) -> Integer
    def waits_for: (String workflow_id) -> Array[workflow_row]
    def with_fence: (workflow_id: String, key: String, ?poll_interval: Numeric, ?timeout: Numeric) { () -> serialized_payload } -> serialized_payload
    def enqueue_outbox: (workflow_id: String, topic: String, payload: serialized_payload, key: String) -> String
    def claim_outbox: (worker_id: String, lease_seconds: Numeric) -> workflow_row?
    def ack_outbox: (String outbox_id, worker_id: String) -> Object
    def outbox_message: (String outbox_id) -> workflow_row?
    def enqueue_inbox_message: (?worker_pool: String, target_kind: String, target_type: String, target_id: String, message_kind: String, ?method_name: String?, ?payload: serialized_payload, ?idempotency_key: String?, ?ready_at: Time?, ?max_attempts: Integer?) -> String
    def enqueue_workflow_command: (workflow_id: String, workflow_name: String, method_name: String, payload: serialized_payload, ?idempotency_key: String?) -> String
    def request_workflow_termination: (workflow_id: String, ?reason: serialized_payload) -> workflow_row
    def claim_target_activation: (worker_id: String, lease_seconds: Numeric, ?target_kinds: Array[String]?, ?target_types: Array[String]?, ?now: Time, ?worker_pool: String) -> workflow_row?
    def complete_target_activation: (?worker_pool: String, target_kind: String, target_type: String, target_id: String, worker_id: String, ?now: Time) -> Object?
    def reconcile_target_activation: (?worker_pool: String, target_kind: String, target_type: String, target_id: String, ?now: Time) -> Object?
    def rearm_target_activation: (?worker_pool: String, target_kind: String, target_type: String, target_id: String, ready_at: Time) -> Object?
    def target_activation: (?worker_pool: String, target_kind: String, target_type: String, target_id: String) -> workflow_row?
    def claim_inbox_messages: (?worker_pool: String, target_kind: String, target_type: String, target_id: String, worker_id: String, ?lease_seconds: Numeric, ?limit: Integer, ?now: Time) -> Array[workflow_row]
    def claim_next_workflow_command: (worker_pool: String, workflow_name: String, workflow_id: String, worker_id: String, lease_seconds: Numeric) -> workflow_row?
    def inbox_message: (String message_id) -> workflow_row?
    def wait_for_inbox_message: (String message_id, ?poll_interval: Numeric, ?timeout: Numeric?) -> serialized_payload
    def inbox_messages_for: (?worker_pool: String?, target_kind: String, target_type: String, target_id: String) -> Array[workflow_row]
    def workflow: (String workflow_id) -> workflow_row
    def steps_for: (String workflow_id) -> Array[workflow_row]
    def step_attempts_for: (String workflow_id) -> Array[workflow_row]
    def step_attempt_count_for: (workflow_id: String, ?command_id: Integer?, ?position: Integer?) -> Integer
    def object_state: (object_type: String, object_id: String, ?worker_pool: String) -> serialized_payload
    def object_state_entry: (object_type: String, object_id: String, ?worker_pool: String) -> serialized_payload
    def save_object_state: (object_type: String, object_id: String, state: serialized_payload, ?worker_pool: String) -> serialized_payload
    def enqueue_object_command: (?worker_pool: String, object_type: String, object_id: String, method_name: String, args: Array[serialized_payload], kwargs: Hash[Symbol, serialized_payload], ?message_kind: String, ?idempotency_key: String?, ?max_attempts: Integer?) -> String
    def claim_object_command: (command_id: String, worker_id: String, ?lease_seconds: Numeric) -> workflow_row?
    def complete_object_command: (command_id: String, result: serialized_payload, ?object_type: String?, ?object_id: String?, ?state: serialized_payload, ?wakeup_changes: Array[ObjectWakeupChange], ?worker_id: String?) -> Object?
    def fail_object_command: (command_id: String, error: String, ?worker_id: String?, ?terminal: bool) -> Object?
    def retry_object_command: (command_id: String, error: String, worker_id: String, ready_at: Time) -> Object?
    def complete_workflow_command: (message_id: String, workflow_id: String, result: serialized_payload, worker_id: String) -> Object?
    def fail_workflow_command: (message_id: String, workflow_id: String, error: String, worker_id: String) -> Object?
  end

  class Workflow[Input, Output, Dispatch = Object]
    def self.workflow_name: (?String value) -> String
    def self.enqueue: (Input input, ?id: String?, ?store: Store, ?engine: Engine, ?worker_pool: String?) -> String
    def self.start: (Input input, ?id: String?, ?store: Store, ?engine: Engine, ?worker_pool: String?) -> workflow_handle[Input, Output, Dispatch]
    def self.at: (String workflow_id, ?store: Store, ?engine: Engine, ?worker_pool: String?) -> workflow_handle[Input, Output, Dispatch]
    def self.handle: (String workflow_id, ?store: Store, ?engine: Engine, ?worker_pool: String?) -> workflow_handle[Input, Output, Dispatch]
    def self.step: (?Symbol method_name, ?retry: retry_config | false | nil) -> Symbol?
    def self.expose: (?Symbol method_name) -> Symbol?
    def self.expose_command: (?Symbol method_name, ?retry: retry_config | false | nil, ?retry_policy: retry_config | false | nil) -> Symbol?

    def __durababble_execution__: () -> WorkflowExecution
    def __durababble_execution__=: (WorkflowExecution? execution) -> WorkflowExecution?
    def __durababble_with_query_context__: () { () -> serialized_payload } -> serialized_payload
    def execute: (Input input) -> Output
    def step_context: () -> StepContext
    def wait_until: (Time time, ?serialized_payload context) -> serialized_payload
    def sleep_until: (Time time, ?serialized_payload context) -> serialized_payload
    def sleep: (Numeric duration, ?serialized_payload context) -> serialized_payload
    def wait_condition: (?timeout: Numeric?) { () -> bool } -> bool
  end

  class WorkflowRef[Input, Output]
    attr_reader workflow_id: String

    def initialize: (singleton(Workflow) workflow_class, String workflow_id, store: Store, ?worker_pool: String?) -> void
    def status: () -> String
    def result: () -> Output?
    def error: () -> String?
    def cancel: (?reason: serialized_payload) -> Run[serialized_payload]
    def terminate: (?reason: serialized_payload) -> Run[serialized_payload]
    def method_missing: (Symbol method_name, *serialized_payload args, **serialized_payload kwargs) -> serialized_payload
    def respond_to_missing?: (Symbol method_name, ?bool include_private) -> bool
  end

  class ObjectWakeupChange
    attr_reader action: Symbol
    attr_reader name: String?
    attr_reader wake_at: Time?
    attr_reader payload: serialized_payload

    def initialize: (Symbol action, String? name, Time? wake_at, serialized_payload payload) -> void
  end

  class DurableObject[Id, State, Dispatch = Object]
    def self.object_type: (?String value) -> String
    def self.at: (Id durable_id, ?store: Store, ?engine: Engine, ?worker_pool: String?, ?idempotency_key: String?) -> durable_object_handle[Id, State, Dispatch]
    def self.handle: (Id durable_id, ?store: Store, ?engine: Engine, ?worker_pool: String?, ?idempotency_key: String?) -> durable_object_handle[Id, State, Dispatch]
    def self.tell: (Id durable_id, Symbol method_name, *serialized_payload args, ?store: Store, ?engine: Engine, ?worker_pool: String?, ?idempotency_key: String?, **serialized_payload kwargs) -> String
    def self.expose: (?Symbol method_name) -> Symbol?
    def self.expose_command: (?Symbol method_name, ?retry: retry_config | false | nil, ?retry_policy: retry_config | false | nil) -> Symbol?

    attr_reader durable_id: Id
    attr_reader command_context: CommandContext?
    attr_reader worker_pool: String

    def initialize_state: () -> State
    def current_state: () -> State
    def update_state: (State state) -> State
    def schedule_wake: (name: String, at: Time, ?payload: serialized_payload) -> Time
    def cancel_wake: (name: String) -> bool
    def cancel_all_wakes: () -> bool
    def state_dirty?: () -> bool
    def wakeup_changes: () -> Array[ObjectWakeupChange]
  end

  class DurableObjectRef[Id, State]
    attr_reader durable_id: Id

    def initialize: (singleton(DurableObject) object_class, Id durable_id, store: Store, ?worker_pool: String?, ?idempotency_key: String?) -> void
    def method_missing: (Symbol method_name, *serialized_payload args, **serialized_payload kwargs) -> serialized_payload
    def respond_to_missing?: (Symbol method_name, ?bool include_private) -> bool
  end

  class DurableObjectTransientHandler
    def self.assert_read_gate_open!: (Store store, object_type: String, object_id: String, ?worker_pool: String) -> void
    def initialize: (store: Store, objects: object_registry, node_id: String | _WorkerIdProvider) -> void
    def call: (request: Object, args: serialized_payload) -> serialized_payload
  end

  class DurableObjectExecutor
    def initialize: (store: Store, objects: object_registry, worker_id: String, lease_seconds: Numeric, ?worker_pool: String) -> void
    def drain_object_inbox: (String object_type, object_id: String, ?limit: Integer) -> Integer
  end

  class WaitRequest
    attr_reader kind: String
    attr_reader wake_at: Time?
    attr_reader event_key: String?
    attr_reader context: serialized_payload

    def initialize: (kind: String, wake_at: Time?, event_key: String?, context: serialized_payload) -> void
  end

  class Engine
    attr_reader store: Store
    attr_reader worker_pool: String

    def initialize: (store: Store, ?worker_id: String, ?lease_seconds: Numeric, ?migrate: bool, ?crash_after: Symbol?, ?worker_pool: String, ?workflow_query_registry: Object?) -> void
    def enqueue: [Input] (singleton(Workflow) workflow_class, input: Input, ?id: String?) -> String
    def run: [Input, Output] (singleton(Workflow) workflow_class, input: Input) -> Run[Output]
    def resume: [Input, Output] (singleton(Workflow) workflow_class, workflow_id: String, ?claimed: workflow_row?) -> Run[Output]
  end

  class Worker
    def initialize: (store: Store, workflows: workflow_registry, worker_id: String, ?objects: object_registry, ?lease_seconds: Numeric, ?migrate: bool, ?worker_pool: String, ?workflow_query_registry: Object?) -> void
    def tick: () -> Symbol
    def deliver_target: (target_kind: String, target_type: String, target_id: String, ?worker_pool: String) -> Symbol
    def run_until_idle: (?max_ticks: Integer) -> Integer
  end

  class WorkerIdentity
    def self.generate: (address: String, ?id: String?) -> String
    def self.build: (id: String, address: String) -> String
    def self.address_for: (String identity) -> String
    def self.id_for: (String identity) -> String?
  end

  class WorkerRuntime
    attr_reader store: Store
    attr_reader workflows: workflow_registry
    attr_reader objects: object_registry
    attr_reader worker_pool: String
    attr_reader worker_id: String
    attr_reader last_error: StandardError?
    attr_reader rpc_address: String?

    def self.start: (workflows: workflow_registry, worker_pool: String, ?objects: object_registry, ?store: Store?, ?database_url: String?, ?schema: String?, ?worker_id: String?, ?lease_seconds: Numeric, ?poll_interval: Numeric, ?migrate: bool, ?rpc_host: String, ?rpc_port: Integer, ?rpc_credentials: Rpc::credentials, ?rpc_pool_size: Integer) -> WorkerRuntime

    def initialize: (workflows: workflow_registry, worker_pool: String, ?objects: object_registry, ?store: Store?, ?database_url: String?, ?schema: String?, ?worker_id: String?, ?lease_seconds: Numeric, ?poll_interval: Numeric, ?migrate: bool, ?rpc_host: String, ?rpc_port: Integer, ?rpc_credentials: Rpc::credentials, ?rpc_pool_size: Integer) -> void
    def start: () -> self
    def shutdown: (?timeout: Numeric) -> (:stopped | :timeout)
    def stop: (?timeout: Numeric) -> (:stopped | :timeout)
    def wait: (?timeout: Numeric?) -> Thread?
    def running?: () -> bool
    def close: () -> void
  end

  class WorkflowExecution
    attr_reader store: Store
    attr_reader step_context: StepContext?
    def call_step: (Workflow[serialized_payload, serialized_payload] instance, method_name: Symbol, args: Array[serialized_payload], kwargs: Hash[Symbol, serialized_payload]) { () -> serialized_payload } -> serialized_payload
    def call_wait: (WaitRequest wait_request, name: String, ?args: Array[serialized_payload], ?kwargs: Hash[Symbol, serialized_payload]) -> serialized_payload
    def call_handle_rpc: (target_kind: String, target_type: String, target_id: String, method_name: Symbol, rpc_kind: String, args: Array[serialized_payload], kwargs: Hash[Symbol, serialized_payload], ?retry_policy: RetryPolicy?) { (idempotency_key: String, args: Array[serialized_payload], kwargs: Hash[Symbol, serialized_payload]) -> serialized_payload } -> serialized_payload
    def wait_condition: (?timeout: Numeric?) { () -> bool } -> bool
    def timer_after: (Numeric duration) -> Time
    def validate_replay_complete!: () -> void
  end

  class RetryPolicy
    attr_reader initial_interval: Float
    attr_reader backoff_coefficient: Float
    attr_reader maximum_interval: Float?
    attr_reader maximum_attempts: Integer | Float
    attr_reader schedule: Array[Float]
    attr_reader non_retryable_errors: Array[Class | String | Symbol]

    def self.from: (retry_config | RetryPolicy | nil value) -> RetryPolicy

    def initialize: (?initial_interval: Numeric, ?backoff_coefficient: Numeric, ?maximum_interval: Numeric?, ?maximum_attempts: Integer?, ?schedule: Array[Numeric]?, ?non_retryable_errors: Array[Class | String | Symbol]) -> void
    def retryable?: (StandardError error, attempt_number: Integer) -> bool
    def delay_for_attempt: (Integer attempt_number) -> Float
  end

  module WorkflowRpc
    class Error < Durababble::Error
    end

    class WorkflowNotRunning < Error
    end

    class NoActiveLease < WorkflowNotRunning
    end

    class NodeUnavailable < Error
    end

    class StaleLease < Error
    end

    class UnknownCommand < Error
    end

    def self.remote_error_from_message: (String message) -> Error?
    def self.remote_error_from_fields: (String klass_name, String message) -> Error?

    class LeaseStarter
      def initialize: (store: Store, worker_ids: Array[String], ?lease_seconds: Numeric, ?await_attempts: Integer, ?await_sleep: _Sleeper) -> void
      def call: (workflow_id: String) -> workflow_row
    end

    class Router
      def initialize: (store: Store, ?rpc_clients: Hash[String, _RpcRequester], ?rpc_client_factory: _WorkflowRpcRouteClientFactory?, ?retry_on_stale: bool, ?start_workflow: _LeaseStarter?, ?start_on_no_active_lease: bool) -> void
      def request: (workflow_id: String, command: String, ?payload: payload_map) -> serialized_payload
    end

    class LocalClient
      def initialize: (store: Store, node_id: String, handlers: Hash[String, _WorkflowRpcHandler]) -> void
      def request: (String command, payload_map payload) -> serialized_payload
    end

    class Handler
      def initialize: (store: Store, node_id: String, handlers: Hash[String, _WorkflowRpcHandler]) -> void
      def call: (payload_map payload) -> serialized_payload
    end
  end

  class WorkflowQueryRegistry
    def initialize: () -> void
    def register: (String workflow_id, singleton(Workflow) workflow_class, Workflow[serialized_payload, serialized_payload] workflow) { () -> serialized_payload } -> serialized_payload
    def call: (workflow_id: String, method_name: String | Symbol, args: Array[serialized_payload], kwargs: Hash[Symbol, serialized_payload]) -> serialized_payload
  end

  module Rpc
    type credentials = Object

    def self.dump: (serialized_payload value, ?surface: Symbol?, ?context: String?) -> String
    def self.load: (String? bytes) -> serialized_payload
    def self.http_client_for: (String address) -> Async::HTTP::Client
    def self.http_client_cached?: (String address) -> bool
    def self.shutdown_http_clients!: () -> void

    class Error < Durababble::Error
    end

    class Unavailable < Error
    end

    class Unauthenticated < Error
    end

    class RemoteError < Error
    end

    class NodeDirectory
      def initialize: (?Hash[String, String] entries) -> void
      def register: (node_id: String, rpc_address: String) -> String
      def rpc_address_for: (String node_id) -> String?
    end

    module Messages
      class AwakenBatchRequest
        attr_reader worker_pool: String
        attr_reader workflow_ids: Array[String]
        def initialize: (?worker_pool: String, ?workflow_ids: Array[String]) -> void
      end

      class AwakenBatchResponse
      end

      class TargetRequest
        attr_reader worker_pool: String
        attr_reader target_kind: String
        attr_reader target_class: String
        attr_reader target_id: String
        attr_reader expected_worker_id: String
        def initialize: (?worker_pool: String, ?target_kind: String, ?target_class: String, ?target_id: String, ?expected_worker_id: String) -> void
      end

      class EvictLeaseRequest < TargetRequest
      end

      class EvictLeaseResponse
      end

      class DeliverMessageRequest < TargetRequest
      end

      class DeliverMessageResponse
      end

      class TransientRequest
        attr_reader worker_pool: String
        attr_reader class_name: String
        attr_reader durable_object_id: String
        attr_reader workflow_id: String
        attr_reader args: String?
        attr_reader deadline_ms: Integer
        attr_reader expected_worker_id: String
        def initialize: (?worker_pool: String, ?class_name: String, ?durable_object_id: String, ?workflow_id: String, ?method: String, ?args: String?, ?deadline_ms: Integer, ?expected_worker_id: String) -> void
        def []: (String | Symbol key) -> Object?
      end

      class LeaseMoved
        attr_reader new_rpc_address: String
        attr_reader new_node_id: String
        def initialize: (?new_rpc_address: String, ?new_node_id: String) -> void
      end

      class RemoteError
        attr_reader klass: String
        attr_reader message: String
        attr_reader backtrace: Array[String]
        def initialize: (?klass: String, ?message: String, ?backtrace: Array[String]) -> void
      end

      class TransientResponse
        attr_reader ok: String?
        attr_reader err: RemoteError?
        attr_reader not_running: bool
        attr_reader moved: LeaseMoved?
        def initialize: (?ok: String?, ?err: RemoteError?, ?not_running: bool, ?moved: LeaseMoved?) -> void
        def result: () -> Symbol?
      end
    end

    class Client
      attr_reader address: String

      def initialize: (address: String, ?credentials: credentials?, ?timeout: Numeric, ?http_client: Object?) -> void
      def awaken_batch: (worker_pool: String, workflow_ids: Array[String]) -> true
      def evict_lease: (worker_pool: String, target_kind: String, ?target_class: String, target_id: String, ?expected_worker_id: String) -> true
      def deliver_message: (worker_pool: String, target_kind: String, ?target_class: String, target_id: String, ?expected_worker_id: String) -> true
      def call_transient_response: (worker_pool: String, method: String, args: serialized_payload, ?class_name: String, ?durable_object_id: String, ?workflow_id: String, ?deadline_ms: Integer, ?expected_worker_id: String) -> Messages::TransientResponse
      def call_transient: (worker_pool: String, method: String, args: serialized_payload, ?class_name: String, ?durable_object_id: String, ?workflow_id: String, ?deadline_ms: Integer, ?expected_worker_id: String) -> serialized_payload
    end

    class WorkflowClient
      def initialize: (address: String, ?worker_pool: String, ?credentials: credentials, ?timeout: Numeric) -> void
      def request: (String command, Hash[String, serialized_payload] payload) -> serialized_payload
    end

    class Server
      attr_reader node_id: String
      attr_reader host: String
      attr_reader port: Integer?

      def initialize: (node_id: String?, store: Store, ?worker_pool: String, ?workflow_handlers: Hash[String, _WorkflowRpcHandler], ?transient_handler: _TransientHandler?, ?node_directory: NodeDirectory, ?host: String, ?port: Integer, ?credentials: credentials?, ?pool_size: Integer?, ?authorize: _RpcAuthorize?, ?awaken_batch: _AwakenBatchHandler?, ?evict_lease: _TargetMessageHandler?, ?deliver_message: _TargetMessageHandler?, ?verify_deliver_message_owner: bool, ?identity_id: String?) -> void
      def start: () -> self
      def stop: () -> void
      def address: () -> String
    end
  end

  attr_accessor self.default_store: Store?
  attr_accessor self.default_engine: Engine?

  def self.default_database_url: () -> String
  def self.default_schema: () -> String
  def self.workspace_schema: (?String? workspace_path, ?prefix: String) -> String
  def self.configure: (database_url: String, ?schema: String) -> Store
  def self.store: () -> Store
  def self.engine: () -> Engine
  def self.engine_for: (?engine: Engine?, ?store: Store?) -> Engine
  def self.store_for: (?engine: Engine?, ?store: Store?) -> Store
  def self.wait_until: (Time time, ?serialized_payload context) -> serialized_payload
  def self.sleep_until: (Time time, ?serialized_payload context) -> serialized_payload
  def self.sleep: (Numeric duration, ?serialized_payload context) -> serialized_payload
  def self.wait_condition: (?timeout: Numeric?) { () -> bool } -> bool
end
