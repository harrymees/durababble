#!/usr/bin/env ruby
# frozen_string_literal: true

require "optparse"
require_relative "../lib/durababble"

COMMAND = ARGV.shift || "version"

class DurababbleCliCounterWorkflow < Durababble::Workflow
  workflow_name "counter"

  def execute(input)
    double(increment(input))
  end

  step def increment(input)
    input.merge("count" => input.fetch("count") + 1)
  end

  step def double(input)
    input.merge("count" => input.fetch("count") * 2)
  end
end

def options
  opts = {
    schema: "durababble",
    database_url: ENV.fetch("DURABABBLE_DATABASE_URL", "postgresql://yugabyte@127.0.0.1:15433/yugabyte"),
    count: 0
  }
  parser = OptionParser.new do |o|
    o.on("--schema SCHEMA") { |value| opts[:schema] = value }
    o.on("--database-url URL") { |value| opts[:database_url] = value }
    o.on("--count N", Integer) { |value| opts[:count] = value }
  end
  parser.parse!(ARGV)
  opts
end

def store_from(opts)
  Durababble::Store.connect(database_url: opts.fetch(:database_url), schema: opts.fetch(:schema))
end

case COMMAND
when "version", "--version", "-v"
  puts "durababble #{Durababble::VERSION}"
when "migrate"
  opts = options
  store = store_from(opts)
  begin
    store.migrate!
    puts "migrated #{opts.fetch(:schema)}"
  ensure
    store.close
  end
when "run-counter"
  opts = options
  store = store_from(opts)
  begin
    run = Durababble::Engine.new(store:).run(DurababbleCliCounterWorkflow, input: { "count" => opts.fetch(:count) })
    puts "#{run.id} #{run.status} #{run.result.inspect}"
  ensure
    store.close
  end
when "resume-counter"
  run_id = ARGV.shift or abort "usage: durababble resume-counter RUN_ID [--schema SCHEMA]"
  opts = options
  store = store_from(opts)
  begin
    run = Durababble::Engine.new(store:).resume(DurababbleCliCounterWorkflow, workflow_id: run_id)
    puts "#{run.id} #{run.status} #{run.result.inspect}"
  ensure
    store.close
  end
when "inspect"
  run_id = ARGV.shift or abort "usage: durababble inspect RUN_ID [--schema SCHEMA]"
  opts = options
  store = store_from(opts)
  begin
    workflow = store.workflow(run_id)
    steps = store.steps_for(run_id)
    puts "workflow=#{workflow.inspect}"
    puts "steps=#{steps.inspect}"
  ensure
    store.close
  end
else
  abort <<~USAGE
    unknown command: #{COMMAND}

    commands:
      version
      migrate --schema SCHEMA
      run-counter --schema SCHEMA --count N
      inspect RUN_ID --schema SCHEMA
      resume-counter RUN_ID --schema SCHEMA
  USAGE
end
